      "driver_metric": "consecutive_days_max_6h",
      "driver_metric_label": "连续多天服务超过6小时的最大天数",
      "unit": "天",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "consecutive_days_max_6h",
        "operator": ">"
