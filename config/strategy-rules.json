{
  "version": "2026-07-07",
  "thresholdDefaults": {
    "source": "death_case_reference",
    "policy": "case_mean",
    "operator": ">",
    "min_sample_count": 30,
    "missing_behavior": "do_not_trigger",
    "threshold_label": "case均值"
  },
  "rules": [
    {
      "key": "service-duration-high",
      "enabled": true,
      "title": "服务时长偏高",
      "category": "workload",
      "priority": 10,
      "condition": {
        "any": [
          {
            "driver_metric": "server_dur_hour",
            "driver_metric_label": "当日服务时长",
            "unit": "小时",
            "threshold": {
              "source": "death_case_reference",
              "policy": "case_mean",
              "reference_metric": "server_dur",
              "operator": ">"
            }
          },
          {
            "driver_metric": "server_dur_hour_30d",
            "driver_metric_label": "近30天服务时长",
            "unit": "小时",
            "threshold": {
              "source": "death_case_reference",
              "policy": "case_mean",
              "reference_metric": "server_dur_sum_30d",
              "operator": ">"
            }
          }
        ]
      },
      "evidence_template": "{{matched_evidence}}。",
      "advice_template": "建议关注司机服务时长是否连续偏高，沟通时提醒把休息排进出车计划，完成较长服务时长后安排间歇休息，避免长期满负荷运行。",
      "tags": [
        "疲劳"
      ]
    },
    {
      "key": "night-work",
      "enabled": true,
      "title": "夜间出车较多",
      "category": "workload",
      "priority": 20,
      "driver_metric": "order_cnt_21_09_7d_rate",
      "driver_metric_label": "夜间出车占比",
      "unit": "",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "order_rate_22_05_30d",
        "operator": ">"
      },
      "evidence_template": "夜间出车占比{{driver_value}}，高于case均值{{threshold_value}}。",
      "advice_template": "沟通时先确认是否长期夜间出车，再引导尽量固定休息时间；如果收入允许，可建议减少连续夜间出车，优先保证睡眠。",
      "tags": [
        "疲劳"
      ]
    },
    {
      "key": "sleep-risk",
      "enabled": true,
      "title": "睡眠状态需关注",
      "category": "fatigue",
      "priority": 30,
      "driver_metric": "sleep_deprivation_days",
      "driver_metric_label": "睡眠不足天数",
      "unit": "天",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "sleep_deprivation_days",
        "operator": ">"
      },
      "evidence_template": "睡眠不足天数{{driver_value}}天，高于case均值{{threshold_value}}天。",
      "advice_template": "建议客服先询问最近休息是否规律，再提醒司机保证连续睡眠时间，疲劳明显时减少接单或暂停出车。",
      "tags": [
        "疲劳"
      ]
    },
    {
      "key": "non-listening-period",
      "enabled": true,
      "title": "近期空闲间隔偏多",
      "category": "workload",
      "priority": 40,
      "driver_metric": "past_7_day_non_listening_period",
      "driver_metric_label": "近7天非听单时段",
      "unit": "",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "past_7_day_non_listening_period",
        "operator": ">"
      },
      "evidence_template": "近7天非听单时段{{driver_value}}，高于case均值{{threshold_value}}。",
      "advice_template": "沟通时可确认司机近期出车节奏是否被等待、休息或其他事务打断，再结合实际情况做关怀提醒。",
      "tags": [
        "节奏"
      ]
    },
    {
      "key": "consecutive-work",
      "enabled": true,
      "title": "连续出车偏多",
      "category": "workload",
      "priority": 50,
      "driver_metric": "consecutive_days",
      "driver_metric_label": "连续出车天数",
      "unit": "天",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "work_days_7d",
        "operator": ">"
      },
      "evidence_template": "连续出车{{driver_value}}天，高于case均值{{threshold_value}}天。",
      "advice_template": "重点提醒司机安排间歇休息，不要长期无休连续跑车；可以建议设置固定休息日，避免疲劳累积影响身体和驾驶安全。",
      "tags": [
        "疲劳"
      ]
    },
    {
      "key": "senior-driver",
      "enabled": true,
      "title": "高龄司机",
      "category": "health",
      "priority": 60,
      "driver_metric": "age",
      "driver_metric_label": "年龄",
      "unit": "岁",
      "threshold": {
        "source": "death_case_reference",
        "policy": "case_mean",
        "reference_metric": "age",
        "operator": ">"
      },
      "evidence_template": "司机年龄{{driver_value}}岁，高于case均值{{threshold_value}}岁。",
      "advice_template": "沟通时关注身体承受情况，提醒避免久坐和过长时间连续驾驶；可以建议中途下车活动，身体不舒服时及时休息。",
      "tags": [
        "高龄"
      ]
    }
  ],
  "fallbackRule": {
    "key": "regular-care",
    "title": "常规关怀",
    "evidence": "当前没有任何指标高于case均值。",
    "advice": "可做常规状态确认，提醒司机保持安全驾驶、合理休息和规律作息。",
    "priority": 999
  }
}
