  "rules": [
    {
      "key": "consecutive-high-intensity",
      "enabled": true,
      "title": "连续高强度服务偏多",
      "category": "workload",
      "priority": 10,
      "priority_tier": "P0",
      "badges": [
        {
          "kind": "high-risk",
          "label": "高风险"
        },
        {
          "kind": "explainable",
          "label": "可解释"
        }
