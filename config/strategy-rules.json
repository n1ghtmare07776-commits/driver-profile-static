          {
            "driver_metric": "is_sleep_deprived",
            "driver_metric_label": "是否睡眠不足",
            "operator": "in",
            "values": [
              "是",
              "1",
              "true",
              "TRUE",
              "Y",
              "y"
            ]
          }
        ]
      },
      "evidence_template": "{{matched_evidence}}。",
      "advice_template": "建议先关怀询问近期睡眠是否充足，再提醒司机疲劳明显时减少接单或暂停出车，优先保证连续睡眠时间。",
      "tags": [
        "疲劳",
        "睡眠"
      ],
      "translation": {
        "driver_script": "师傅您好，想关心一下您最近睡眠情况。平台侧看到您近期可能存在休息不足的情况，您现在精神状态还好吗？",
        "action_advice": "建议疲劳明显时先减少接单或暂停出车，优先保证一段连续、稳定的睡眠。",
        "communication_tip": "高风险且容易解释，先问状态，再给休息建议。"
      }
    },
