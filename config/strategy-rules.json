{
  "version": "2026-07-09",
  "thresholdDefaults": {
    "source": "death_case_reference",
    "policy": "case_mean",
    "operator": ">",
    "min_sample_count": 30,
    "missing_behavior": "do_not_trigger",
    "threshold_label": "case均值"
  },
  "rules": [
    {
      "key": "consecutive-high-intensity",
      "enabled": true,
      "title": "连续高强度服务偏多",
      "category": "workload",
      "priority": 10,
      "priority_tier": "P0",
      "badges": [
        {
          "kind": "high-risk",
          "label": "高风险"
        },
        {
          "kind": "explainable",
          "label": "可解释"
        }
      ],
      "condition": {
        "any": [
          {
            "driver_metric": "consecutive_days_max_6h",
            "driver_metric_label": "连续多天服务超过6小时的最大天数",
            "unit": "天",
            "threshold": {
              "source": "death_case_reference",
              "policy": "case_mean",
              "reference_metric": "consecutive_days_max_6h",
              "operator": ">"
            }
          },
          {
            "driver_metric": "consecutive_days_max",
            "driver_metric_label": "近90天最高连日出车天数",
            "unit": "天",
            "threshold": {
              "source": "death_case_reference",
              "policy": "case_mean",
              "reference_metric": "consecutive_days_max_90d",
              "operator": ">"
            }
          },
          {
            "driver_metric": "consecutive_days",
            "driver_metric_label": "连续出车天数",
            "unit": "天",
            "threshold": {
              "source": "death_case_reference",
              "policy": "case_mean",
              "reference_metric": "work_days_7d",
              "operator": ">"
            }
          },
          {
            "driver_metric": "is_long_consecutive",
            "driver_metric_label": "是否长期连日出车",
            "operator": "in",
            "values": [
              "是",
              "1",
              "true",
              "TRUE",
              "Y",
              "y"
            ]
          }
        ]
      },
      "evidence_template": "{{matched_evidence}}。",
      "advice_template": "建议重点确认司机近期是否连续多天长时间服务，沟通时提醒把固定休息日排进出车计划，避免疲劳持续累积。",
      "tags": [
        "疲劳",
        "高强度"
      ],
      "translation": {
        "driver_script": "师傅您好，看到您最近连续高强度出车比较多，想先关心一下您这两天休息得怎么样，身体状态还好吗？",
        "action_advice": "建议您把固定休息时间提前排进出车计划，连续服务时间较长后尽量安排间歇休息。",
        "communication_tip": "优先沟通，先确认当前状态；不要提 case 均值或内部阈值。"
      }
    },
    {
      "key": "minimum-sleep-low",
      "enabled": true,
      "title": "睡眠不足需关注",
      "category": "fatigue",
      "priority": 20,
      "priority_tier": "P0",
      "badges": [
        {
          "kind": "high-risk",
          "label": "高风险"
        },
        {
          "kind": "explainable",
          "label": "可解释"
        }
      ],
      "condition": {
        "any": [
          {
            "driver_metric": "min_sleep_duration",
            "driver_metric_label": "最短睡眠时长",
